-- Run this in Supabase SQL Editor after replacing the placeholders.
-- Keep ACCOUNT_DELETION_CRON_SECRET private; do not commit the filled version.

create extension if not exists pg_cron with schema extensions;
create extension if not exists pg_net with schema extensions;

select cron.unschedule('account-deletion-job')
where exists (
  select 1
  from cron.job
  where jobname = 'account-deletion-job'
);

select cron.schedule(
  'account-deletion-job',
  '30 3 * * *',
  $$
  select net.http_post(
    url := 'https://YOUR_PROJECT_REF.supabase.co/functions/v1/process-account-deletions',
    headers := jsonb_build_object(
      'Authorization', 'Bearer YOUR_ACCOUNT_DELETION_CRON_SECRET',
      'Content-Type', 'application/json'
    ),
    body := '{"dryRun": false}'::jsonb
  );
  $$
);
